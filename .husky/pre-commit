echo "🛡️  Sentinel-AI: Running Pre-Commit Audit..."

# 1. Prevent .env leaks (Strict check for exact filename)
if git diff --cached --name-only | grep -E '^(.env|\.env\..*)$'; then
  echo "❌ Error: Sentinel detected .env file. Secrets must not be committed!"
  exit 1
fi

# 2. Check Gateway (Using the correct folder name)
echo "📦 Checking Gateway Build..."
if [ -d "sentinel-gateway" ]; then
    cd sentinel-gateway && npm run build
    if [ $? -ne 0 ]; then
      echo "❌ Error: Gateway build failed. Fix TypeScript/Linting issues."
      exit 1
    fi
    cd ..
else
    echo "⚠️ Warning: sentinel-gateway folder not found, skipping build check."
fi

# 3. Check Worker (Using the correct path)
echo "🐍 Checking Python Worker Syntax..."
if [ -d "sentinel-worker" ]; then
    # Yahan path correct kar diya hai worker folder ke hisab se
    python -m compileall -q sentinel-worker/src/
    if [ $? -ne 0 ]; then
      echo "❌ Error: Python syntax error in Worker."
      exit 1
    fi
else
    echo "⚠️ Warning: sentinel-worker folder not found, skipping syntax check."
fi

echo "✅ Sentinel-AI: Audit Passed. Committing code..."
